---
// Cards.astro - 优化后的版本，保持左右交错布局
import { filterItems } from '../data/content';
---

<div class="projects-list">
  <!-- 项目0 - Ben the Otter (Sticker Design) -->
  <div class="project-row">
    <div class="project-content left">
      <div class="project-info">
        <h2 class="project-title"><a href="/newportfolio/detail/stickers">Ben the Otter</a></h2>
        <p class="project-desc">An original character sticker series. Two expressive sets, developed through AI-assisted design and published on the WeChat Sticker Gallery.</p>
        <div class="project-tag">Illustration & Character Design</div>
      </div>
    </div>
    <div class="project-media right">
      <a href="/newportfolio/detail/stickers" class="project-link">
        <div class="project-image">
          <img src="/newportfolio/assets/cover/cover-stickers.png" alt="Ben the Otter, original sticker character design" />
        </div>
      </a>
    </div>
  </div>

  <!-- 项目1 - Natsu -->
  <div class="project-row reverse">
    <div class="project-content right">
      <div class="project-info">
        <h2 class="project-title"><a href="/newportfolio/detail/natsu">Natsu</a></h2>
        <p class="project-desc">A UX case study on transforming a restaurant's ordering tool, improving usability, and elevating the brand experience through user-centric design.</p>
        <div class="project-tag">Menu design</div>
      </div>
    </div>
    <div class="project-media left">
      <a href="/newportfolio/detail/natsu" class="project-link">
        <div class="project-image">
          <img src="/newportfolio/assets/cover/cover-natsu.png" alt="Natsu - menu redesign" />
        </div>
      </a>
    </div>
  </div>
  
  <!-- 项目2 - Agora -->
  <div class="project-row">
    <div class="project-content left">
      <div class="project-info">
        <h2 class="project-title"><a href="/newportfolio/detail/agora">Agora</a></h2>
        <p class="project-desc">A platform connecting students through shared academic interests and resources.</p>
        <div class="project-tag">UX/UI design</div>
      </div>
    </div>
    <div class="project-media right">
      <a href="/newportfolio/detail/agora" class="project-link">
        <div class="project-image">
          <img src="/newportfolio/assets/cover/cover-agora.jpg" alt="Agora - A platform connecting students" />
        </div>
      </a>
    </div>
  </div>

  <!-- 项目3 - Manse -->
  <div class="project-row reverse">
    <div class="project-content right">
      <div class="project-info">
        <h2 class="project-title"><a href="/newportfolio/detail/manse">Manse</a></h2>
        <p class="project-desc">An intelligent feedback bot designed to enhance user experience through personalized interactions.</p>
        <div class="project-tag">UX/UI design</div>
      </div>
    </div>
    <div class="project-media left">
      <a href="/newportfolio/detail/manse" class="project-link">
        <div class="project-image">
          <img src="/newportfolio/assets/cover/cover-manse.png" alt="Manse - A feedback bot" />
        </div>
      </a>
    </div>
  </div>

  <!-- 项目4 - Ecjoy -->
  <div class="project-row">
    <div class="project-content left">
      <div class="project-info">
        <h2 class="project-title"><a href="/newportfolio/detail/ecjoy">Ecjoy</a></h2>
        <p class="project-desc">Discover and join your perfect hobby classes with a seamless, intuitive browsing experience.</p>
        <div class="project-tag">UI/UX design</div>
      </div>
    </div>
    <div class="project-media right">
      <a href="/newportfolio/detail/ecjoy" class="project-link">
        <div class="project-image">
          <img src="/newportfolio/assets/cover/cover-ecjoy.png" alt="Ecjoy - An application for finding hobby classes" />
        </div>
      </a>
    </div>
  </div>

  <!-- 项目5 - Buckethead -->
  <div class="project-row reverse">
    <div class="project-content right">
      <div class="project-info">
        <h2 class="project-title"><a href="/newportfolio/detail/buckethead">Buckethead</a></h2>
        <p class="project-desc">A playful educational game that combines learning with fun interactive challenges.</p>
        <div class="project-tag">Game</div>
      </div>
    </div>
    <div class="project-media left">
      <a href="/newportfolio/detail/buckethead" class="project-link">
        <div class="project-image">
          <img src="/newportfolio/assets/cover/cover-buckethead.png" alt="Buckethead - An educational game" />
        </div>
      </a>
    </div>
  </div>
</div>

<style>
  /* 优化的项目展示样式 */
  .projects-list {
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .project-row {
    display: flex;
    align-items: center;
    margin-bottom: 72px;
    gap: 48px;
  }

  .project-row.reverse {
    flex-direction: row-reverse;
  }

  .project-content {
    flex: 0 0 50%;
    padding: 0;
  }

  .project-media {
    flex: 0 0 42%;
  }

  .project-image {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .project-image:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
  }

  .project-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  .project-image:hover img {
    transform: scale(1.02);
  }

  .project-title {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-100);
  }

  .project-title a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .project-title a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
    opacity: 0.75;
  }

  .project-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: var(--color-400);
  }

  .project-tag {
    font-size: 0.9rem;
    color: var(--color-500);
    display: inline-block;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  /* 响应式调整 */
  @media (max-width: 1200px) {
    .project-row {
      gap: 40px;
    }
  }

  @media (max-width: 900px) {
    .project-row, 
    .project-row.reverse {
      flex-direction: column;
      gap: 30px;
      margin-bottom: 80px;
    }
    
    .project-content,
    .project-media {
      flex: 0 0 100%;
      padding: 0;
    }
    
    .project-title {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 576px) {
    .project-title {
      font-size: 1.5rem;
    }
    
    .project-desc {
      font-size: 1rem;
    }
  }
</style>