---
// src/pages/research.astro
import BlogPostLayout from "../layouts/BlogPostLayout.astro";
import { pageDescription, researchTdk } from "../data/content";
import { publications } from "../data/publications";

// 小工具：把 authors 统一成文本；并按年份倒序
const toAuthorsText = (v:any) => Array.isArray(v) ? v.join(", ") : (v ?? "");
const items = (publications ?? []).slice().sort((a:any,b:any)=> (b?.year ?? 0) - (a?.year ?? 0));
---

<BlogPostLayout
  title={researchTdk.title || ""}
  description={researchTdk.description || ""}
  keywords={researchTdk.keywords || ""}
>
  <div class="post">
    <main class="post-wrapper research">
            <header class="page-head results">
        <span class="page-kicker">Research</span>
        <h1 class="page-title">Publications</h1>
        <p class="page-intro">{pageDescription.research}</p>
      </header>

      <section style="padding-top: 1rem;">
        <div class="content results">
          {items.map((p:any) => {
            const titleHref = p.link || p.publisherUrl || p.url || "";
            const venueEl = p.venueUrl
              ? <a href={p.venueUrl} target="_blank" rel="noopener">{p.venue}</a>
              : p.venue;

            return (
              <article class="result">
                <div class="result-head">
                  <span class="type">
                    {p.type}{p.openAccess ? " • Open access" : ""}
                  </span>
                  {p.status && <span class="status">{p.status}</span>}
                  {typeof p.citedBy === "number" && p.citedBy > 0 && (
                    <span class="cited">Cited by {p.citedBy}</span>
                  )}
                </div>

                <h3 class="title">
                  {titleHref
                    ? <a href={titleHref} target="_blank" rel="noopener">{p.title}</a>
                    : p.title}
                </h3>

                <div class="authors">{toAuthorsText(p.authors)}</div>
                <div class="venue">
                  {venueEl}{p.year ? `, ${p.year}` : ""}
                </div>

                {p.award && (
                  <div class="award">🏆 {p.award}</div>
                )}

                {p.contribution && (
                  <div class="contribution">{p.contribution}</div>
                )}

                <div class="actions">
                  {p.abstract && (
                    <details class="disclose">
                      <summary>Abstract</summary>
                      <p>{p.abstract}</p>
                    </details>
                  )}

                  {p.video && (
                    <details class="disclose">
                      <summary>Watch demo video</summary>
                      <div class="video">
                        <iframe
                          src={`https://www.youtube-nocookie.com/embed/${p.video}`}
                          title={`${p.title} demo video`}
                          loading="lazy"
                          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                          allowfullscreen
                        ></iframe>
                      </div>
                    </details>
                  )}

                  {(p.publisherUrl || p.link || p.url) && (
                    <a class="action-link" href={p.publisherUrl || p.link || p.url} target="_blank" rel="noopener">
                      View at publisher ↗
                    </a>
                  )}

                  {(p.pdf || p.fullTextUrl) && (
                    <a class="action-link" href={p.pdf || p.fullTextUrl} target="_blank" rel="noopener">
                      Full text ↗
                    </a>
                  )}

                  {p.relatedUrl && (
                    <a class="action-link" href={p.relatedUrl} target="_blank" rel="noopener">
                      Related documents ↗
                    </a>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </section>
    </main>
  </div>
</BlogPostLayout>

<style>
  .results { max-width: 960px; margin: 0 auto; }
  .results { padding-left: 20px; padding-right: 20px; }
  .page-head { margin: 1.5rem auto 3rem; text-align: center; }
  .page-kicker { display:block; text-transform:uppercase; letter-spacing:.16em; font-size:.8rem; font-weight:700; color:var(--color-accent); margin-bottom:.5rem; }
  .page-title { font-size: clamp(2rem, 4vw, 2.8rem); line-height:1.1; font-weight:600; margin:0 0 1rem; color:var(--color-100); }
  .page-intro { max-width: 62ch; margin: 0 auto; text-align: center; text-wrap: balance; color: var(--color-300, var(--color-text)); font-size:1.05rem; line-height:1.7; }
  @media (max-width: 640px) {
    .page-intro { text-align: left; }
  }

  .result { padding: 1.25rem 0; border-bottom: 1px solid var(--color-border, rgba(0,0,0,.1)); }
  .result:last-child { border-bottom: none; }

  .result-head{ display:flex; gap:.75rem; align-items:center; color: var(--color-text-secondary); font-size:.9rem; }
  .type{ background: var(--color-chip-bg, rgba(127,127,127,.12)); padding:.15rem .5rem; border-radius: .5rem; }
  .cited{ margin-left:auto; }

  .title{ font-size:1.15rem; margin:.35rem 0 .25rem; line-height:1.35; }
  .title a{ color: var(--color-100); text-decoration:none; }
  .title a:hover{ text-decoration: underline; }

  .authors{ color: var(--color-text-secondary); margin-bottom:.1rem; }
  .venue{ color: var(--color-text-secondary); font-size:.95rem; }

  .status{ background: rgba(64,160,96,.14); color: var(--color-100); padding:.15rem .5rem; border-radius:.5rem; }
  .award{
    display:inline-block;
    margin-top:.5rem;
    font-size:.9rem;
    font-weight:500;
    color: var(--color-100);
  }
  .contribution{ margin-top:.4rem; font-size:.95rem; color: var(--color-text-secondary); font-style: italic; }

  /* one consistent, quiet action row */
  .actions{ display:flex; gap:.4rem 1.5rem; align-items:baseline; flex-wrap:wrap; margin-top:.7rem; }
  .action-link, .disclose > summary{
    color: var(--color-accent);
    font-weight:500;
    font-size:.92rem;
    text-decoration:none;
    cursor:pointer;
    list-style:none;
  }
  .action-link:hover, .disclose > summary:hover{ text-decoration:underline; }
  .disclose{ }
  .disclose[open]{ flex-basis:100%; }
  .disclose[open] > summary{ margin-bottom:.6rem; }
  .disclose p{ margin:0; max-width:72ch; color: var(--color-text); font-size:.95rem; line-height:1.7; }

  .video{
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: .75rem;
    overflow: hidden;
    background: rgba(127,127,127,.08);
  }
  .video iframe{ width:100%; height:100%; border:0; display:block; }

  @media (max-width: 720px){
    .title{ font-size:1.05rem; }
    .cited{ display:none; }
  }
</style>
