---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait.jpg';
import {homeTdk, socialLinks} from '../data/content';
import { publications } from '../data/publications';
const baseUrl = import.meta.env.BASE_URL;

const cvLink = socialLinks.find((s:any) => s.name === 'Resume')?.url || '#';
const contactEmail = 'moshi.qin@tuni.fi';
// Only these icons show in the hero; CV has its own button, email has a contact line.
const heroSocials = socialLinks.filter((s:any) => s.name === 'Linkedin' || s.name === 'Google Scholar');

// Selected research shown on the landing page (most recent / award-winning)
const highlights = publications
  .filter((p:any) => p.award || p.status)
  .slice(0, 3);

const base = '/newportfolio';
const projects = [
  { title: 'Ben the Otter', tag: 'Illustration & Character Design', cover: `${base}/assets/cover/cover-stickers.png`, href: `${base}/detail/stickers` },
  { title: 'Natsu', tag: 'Menu Design', cover: `${base}/assets/cover/cover-natsu.png`, href: `${base}/detail/natsu` },
  { title: 'Agora', tag: 'UX/UI Design', cover: `${base}/assets/cover/cover-agora.jpg`, href: `${base}/detail/agora` },
  { title: 'Manse', tag: 'UX/UI Design', cover: `${base}/assets/cover/cover-manse.png`, href: `${base}/detail/manse` },
  { title: 'Ecjoy', tag: 'UI/UX Design', cover: `${base}/assets/cover/cover-ecjoy.png`, href: `${base}/detail/ecjoy` },
  { title: 'Buckethead', tag: 'Game Design', cover: `${base}/assets/cover/cover-buckethead.png`, href: `${base}/detail/buckethead` },
];
---

<BaseLayout
title={homeTdk.title  || ''}
description ={homeTdk.description  || ''}
keywords = {homeTdk.keywords  || ''}
>
	<!-- ===== HERO / INTRO ===== -->
	<section class="intro">
		<div class="container intro-grid home-narrow">
			<div class="intro-text">
				<p class="intro-eyebrow">PhD Researcher · <span class="role-full">Human&#8209;Computer Interaction</span><span class="role-short">HCI</span></p>
				<h1 class="intro-name">Moshi Qin</h1>
				<p class="intro-affil"><span class="affil-full">TAUCHI Research Center, Tampere University · Finland</span><span class="affil-short">Tampere University · Finland</span></p>

				<p class="intro-bio">
					I study how people communicate and self&#8209;regulate through everyday
					signals such as emojis, gaze, and gesture, and I pair that
					human&#8209;computer interaction research with hands&#8209;on design.
				</p>

				<div class="intro-award">🏆 People's Choice Student Challenge Award, UbiComp 2025</div>

				<div class="intro-actions">
					<a class="btn-primary" href={cvLink} target="_blank" rel="noopener">Download CV</a>
					<div class="intro-socials">
						{heroSocials.map((s:any) => (
							<a href={s.url} target="_blank" rel="noopener" aria-label={s.name} title={s.name} set:html={s.icon} />
						))}
					</div>
				</div>

				<p class="intro-contact">Get in touch: <a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
			</div>

			<div class="intro-photo">
				<Image src={portrait} alt="Portrait of Moshi Qin" widths={[320, 520]} sizes="(max-width: 800px) 60vw, 340px" />
			</div>
		</div>
	</section>

	<!-- ===== ABOUT ===== -->
	<section class="home-about" id="about">
		<div class="container home-narrow">
			<div class="section-head">
				<div>
					<span class="section-kicker">About</span>
					<h2 class="section-title">A little about me</h2>
				</div>
			</div>
			<div class="about-text">
				<p>I'm a researcher and designer in human-computer interaction who cares about making technology intuitive and genuinely human. My background is in Human&#8209;Technology Interaction, with a strong foundation in user research, and I like working across the whole picture, from game design to cognitive load analysis, to understand how technology can better serve the people using it.</p>
				<p>Outside of research, you'll probably find me baking something sweet, sipping a good cup of coffee, solving puzzles, or trying to escape a themed room (hopefully successfully). I also love just sitting under the sun, soaking in the moment.</p>
			</div>
		</div>
	</section>

	<!-- ===== SELECTED RESEARCH ===== -->
	<section class="home-research" id="research">
		<div class="container home-narrow">
			<div class="section-head">
				<div>
					<span class="section-kicker">Research</span>
					<h2 class="section-title">Selected Research</h2>
				</div>
				<a class="see-all" href="/newportfolio/research">View all publications →</a>
			</div>
			<div class="research-cards">
				{highlights.map((p:any) => (
					<a class="research-card" href="/newportfolio/research">
						{p.award && <span class="rc-badge award">🏆 Award</span>}
						{p.status && !p.award && <span class="rc-badge status">{p.status}</span>}
						<h3>{p.title}</h3>
						<p class="rc-venue">{p.venue}{p.year ? `, ${p.year}` : ''}</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- ===== SELECTED WORK ===== -->
	<section class="home-portfolio-section" id="work">
		<div class="container home-narrow">
			<div class="section-head">
				<div>
					<span class="section-kicker">Work</span>
					<h2 class="section-title">Selected Work</h2>
				</div>
			</div>
			<div class="work-grid">
				{projects.map((p) => (
					<a class="work-card" href={p.href}>
						<div class="work-cover"><img src={p.cover} alt={p.title} loading="lazy" /></div>
						<div class="work-meta">
							<h3>{p.title}</h3>
							<span class="work-tag">{p.tag}</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

</BaseLayout>

<style>
  /* Shared content width so every section lines up */
  .home-narrow {
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
  }
  @media (max-width: 480px) {
    .home-narrow { padding-left: 18px; padding-right: 18px; }
  }

  /* ===== HERO ===== */
  .intro { padding: 3.5rem 0 2rem; }
  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.9fr);
    gap: 3.5rem;
    align-items: center;
  }
  .intro-text { min-width: 0; }
  .affil-short { display: none; }
  .role-short { display: none; }
  .intro-eyebrow, .intro-affil, .intro-bio { overflow-wrap: break-word; }
  .intro-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
  }
  .intro-name {
    font-size: clamp(2.8rem, 6vw, 4.4rem);
    line-height: 1.02;
    font-weight: 600;
    color: var(--color-100);
    margin: 0 0 0.75rem;
  }
  .intro-affil {
    color: var(--color-400, var(--color-text-secondary));
    font-size: 1rem;
    margin: 0 0 1.25rem;
  }
  .intro-bio {
    color: var(--color-300, var(--color-text));
    font-size: 1.1rem;
    line-height: 1.65;
    max-width: 42ch;
    margin: 0 0 1.5rem;
  }
  .intro-award {
    display: inline-block;
    font-size: 0.92rem;
    font-weight: 500;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    background: rgba(212, 164, 32, 0.14);
    border: 1px solid rgba(212, 164, 32, 0.45);
    color: var(--color-100);
    margin-bottom: 1.75rem;
    max-width: 100%;
  }
  .intro-contact {
    font-size: 0.95rem;
    color: var(--color-400, var(--color-text-secondary));
    margin: 0 0 1rem;
  }
  .intro-contact a { color: var(--color-accent); text-decoration: none; }
  .intro-contact a:hover { text-decoration: underline; }
  .intro-actions {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    background: #f7d252;
    color: #1a1a1a;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(247,210,82,0.45); }
  .btn-secondary {
    display: inline-block;
    padding: 0.7rem 1.35rem;
    border-radius: 999px;
    border: 1px solid var(--color-border, rgba(127,127,127,0.3));
    color: var(--color-100);
    text-decoration: none;
    font-weight: 500;
    transition: border-color 0.2s ease;
  }
  .btn-secondary:hover { border-color: var(--color-accent); }

  .intro-socials {
    display: flex;
    gap: 0.9rem;
    align-items: center;
  }
  .intro-socials a { display: inline-flex; opacity: 0.6; transition: opacity 0.2s ease; }
  .intro-socials a:hover { opacity: 1; }
  .intro-socials :global(svg) { width: 22px; height: 22px; fill: var(--color-100); }

  .intro-photo { justify-self: center; }
  .intro-photo :global(img) {
    width: 100%;
    max-width: 340px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: 50% 30%;
    border-radius: 18px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
  }

  /* ===== SHARED SECTION HEADINGS (chapter style) ===== */
  .home-about, .home-research, .home-portfolio-section {
    padding: 2.75rem 0;
    border-top: 1px solid var(--color-border, rgba(127,127,127,0.15));
    scroll-margin-top: 90px;
  }
  .home-portfolio-section { padding-bottom: 4.5rem; }

  .section-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;
  }
  .section-kicker {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-size: clamp(1.9rem, 3.5vw, 2.6rem);
    line-height: 1.1;
    font-weight: 600;
    margin: 0;
    color: var(--color-100);
  }
  .see-all { color: var(--color-accent); text-decoration: none; font-weight: 500; white-space: nowrap; }
  .see-all:hover { text-decoration: underline; }

  /* ===== ABOUT ===== */
  .about-text { max-width: 68ch; }
  .about-text p { font-size: 1.08rem; line-height: 1.8; color: var(--color-300, var(--color-text)); margin: 0 0 1.25rem; }
  .about-text p:last-child { margin-bottom: 0; }

  /* ===== RESEARCH CARDS ===== */
  .research-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .research-card {
    display: block; text-decoration: none; color: inherit;
    padding: 1.4rem; border-radius: 14px;
    border: 1px solid var(--color-border, rgba(127,127,127,0.15));
    background: var(--color-bg-secondary, rgba(127,127,127,0.04));
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .research-card:hover { transform: translateY(-4px); border-color: var(--color-accent); }
  .rc-badge { display: inline-block; font-size: 0.78rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 999px; margin-bottom: 0.75rem; }
  .rc-badge.award { background: rgba(212,164,32,0.16); color: var(--color-100); border: 1px solid rgba(212,164,32,0.4); }
  .rc-badge.status { background: rgba(64,160,96,0.16); color: var(--color-100); border: 1px solid rgba(64,160,96,0.4); }
  .research-card h3 { font-size: 1.05rem; line-height: 1.35; margin: 0 0 0.5rem; color: var(--color-100); }
  .rc-venue { font-size: 0.9rem; color: var(--color-400, var(--color-text-secondary)); margin: 0; }

  /* ===== WORK CARDS ===== */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.75rem;
  }
  .work-card {
    display: block; text-decoration: none; color: inherit;
    border-radius: 16px; overflow: hidden;
    border: 1px solid var(--color-border, rgba(127,127,127,0.15));
    background: var(--color-bg-secondary, rgba(127,127,127,0.04));
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .work-card:hover { transform: translateY(-5px); box-shadow: 0 14px 30px rgba(0,0,0,0.12); }
  .work-cover { aspect-ratio: 16 / 10; background: #fff; overflow: hidden; }
  .work-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .work-meta { padding: 1rem 1.15rem 1.25rem; }
  .work-meta h3 { font-size: 1.15rem; margin: 0 0 0.35rem; color: var(--color-100); }
  .work-tag { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-400, var(--color-text-secondary)); }

  @media (max-width: 820px) {
    .intro { padding-top: 1.5rem; }
    .intro-grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.25rem;
    }
    .intro-text { display: flex; flex-direction: column; align-items: center; max-width: 360px; }
    .intro-bio, .intro-award { display: none; }
    .intro-actions, .intro-socials { justify-content: center; }
    .affil-full { display: none; }
    .affil-short { display: inline; }
    .role-full { display: none; }
    .role-short { display: inline; }

    /* circular avatar on top */
    .intro-photo { order: -1; }
    .intro-photo :global(img) {
      max-width: 150px;
      border-radius: 50%;
      object-position: 50% 26%;
    }

    /* name, then role subtitle, then affiliation */
    .intro-name { order: 1; font-size: clamp(1.9rem, 8vw, 2.4rem); margin: 0 0 0.35rem; }
    .intro-eyebrow {
      order: 2;
      text-transform: none;
      letter-spacing: 0.01em;
      font-weight: 500;
      font-size: 1rem;
      color: var(--color-300, var(--color-text));
      margin: 0 0 0.25rem;
    }
    .intro-affil { order: 3; font-size: 0.9rem; margin: 0 0 1.4rem; }
    .intro-actions { order: 4; margin-bottom: 0.9rem; }
    .intro-contact { order: 5; font-size: 0.9rem; }
  }
</style>

<style is:global>
  html { scroll-behavior: smooth; }
</style>


